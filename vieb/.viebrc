nmap <C-j> <backInHistory>
nmap <C-k> <forwardInHistory>

cmap jk <toNormalMode>
emap jk <toNormalMode>
imap jk <toNormalMode>
pmap jk <toNormalMode>
smap jk <toNormalMode>
vmap jk <toNormalMode>

set firefoxmode=google

nmap <C-q> <moveTabForward>
nmap <C-a> <moveTabBackward>

nmap <C-h> <previousTab>
nmap <C-l> <nextTab>

/* emap <C-j> <exploreHistoryNext> */
/* emap <C-k> <exploreHistoryPrevious> */

emap <C-j> <nextSuggestion>
emap <C-k> <prevSuggestion>
emap <c-l> <useentereddata>

cmap <C-j> <nextSuggestion>
cmap <C-k> <prevSuggestion>
cmap <C-l> <useEnteredData>

nmap <,-space> <emptySearch>

emap <C-h> <C-a><Del>
cmap <C-h> <C-a><Del>
